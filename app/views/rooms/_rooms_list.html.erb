<% rooms.each do |room| %>
  <div class="col-md-6">
    <div class="panel panel-default">
      <div class="panel-heading preview">
        <%= link_to image_tag(room.cover_photo(:medium)), room %>
        <div class="price-box-wrapper pull-right">$<%= room.price %></div>
      </div>
      
      <div class="panel-body">
        <div class="container">
          <span class="col-md-12" style="padding-left: auto; padding-right: 0px;"><%= link_to room.listing_name, room %></span></br>
          <span class="col-md-12" style="padding-left: auto; padding-right: 0px;"><span id="star_<%= room.id %>"></span>&nbsp;<%= pluralize(room.average_rating, "review") %>
          <!--<span class="price-box-wrapper pull-right"><b>$<= room.price %></b></span>-->
          <% if current_user && current_user.id == 1 %>
            
          <% else %>
            <button class="btn btn-form btn-normal pull-right">
              <%= link_to "Book Now", room_path(id: 1), style: "color: white; text-decoration: none;" %>
            </button>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  
  <script>
    $('#star_<%= room.id %>').raty({
      path: '/assets',
      readOnly: true,
      score: <%= room.average_rating %>
    });
  </script>
<% end %>